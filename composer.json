{
    "name": "vitalink/content-improver",
    "description": "Multi-provider AI content improvement for the WordPress block editor.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": ["wordpress", "ai", "openai", "anthropic", "ollama", "gutenberg", "content"],
    "homepage": "https://github.com/vitalink/content-improver",
    "authors": [
        {
            "name": "Jason G.",
            "homepage": "https://upwork.com",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/vitalink/content-improver/issues",
        "source": "https://github.com/vitalink/content-improver"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.11",
        "wp-phpunit/wp-phpunit": "^6.5",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Vitalink\\ContentImprover\\": "trunk/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vitalink\\ContentImprover\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "test:ci": "@test",
        "lint": "phpcs --standard=.phpcs.xml.dist trunk/src tests",
        "lint:fix": "phpcbf --standard=.phpcs.xml.dist trunk/src tests",
        "stan": "phpstan analyse trunk/src --level=6",
        "build": "wp-scripts build",
        "start": "wp-scripts start"
    }
}
